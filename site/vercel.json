{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.py" },
    { "source": "/api/clear", "destination": "/api/clear.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
